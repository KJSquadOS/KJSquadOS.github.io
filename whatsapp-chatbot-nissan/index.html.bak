      { type: 'typing', delay: 1000 },
      { type: 'bot', msg: '확인해주셨군요, 감사합니다! 🙏<br><br>정확한 진단을 위해 전문 상담사에게 연결해드리겠습니다.<br>잠시만 기다려주세요. (예상 대기: 약 2분)', delay: 2500, buttons: [
        { text: '👤 상담사 연결', url: true }
      ]},
      { type: 'typing', delay: 3000 },
      { type: 'bot', msg: '✅ <strong>상담사 Ahmed</strong>님 연결 완료<br><br>"안녕하세요, 고객님! 😊 Altima 엔진 경고등 관련 상담 도와드리겠습니다.<br><br>연료 캡은 이미 확인하셨군요. 가까운 서비스 센터 점검 예약을 도와드릴까요?"', delay: 3000, buttons: [
        { text: '📅 서비스 센터 예약', reply: false },
        { text: '💬 채팅 계속', reply: false }
      ]}
    ]
  }
};

/* ══════════════════════════════
   DEMO ENGINE
══════════════════════════════ */
let currentScenario = 'scenario-1';
let currentTimers = [];

function buildFlowHtml(flow){
  return flow.map((f,i) => {
    const cls = f.done ? 'done' : f.current ? 'current' : '';
    const dot = f.done ? '' : (f.current ? '●' : String(i+1));
    return `<div class="flow-step ${cls}"><div class="flow-dot">${dot}</div>${f.label}</div>${i < flow.length-1 ? '<span class="flow-arr">›</span>' : ''}`;
  }).join('');
}

function buildInfo(key){
  const d = scenarios[key];
  document.getElementById('scenario-info').innerHTML = `
    <div class="demo-info-badge">${d.badge}</div>
    <h3>${d.name}</h3>
    <p>${d.desc}</p>
    <div class="flow-row">${buildFlowHtml(d.flow)}</div>
    <div class="feature-pills">${d.features.map(f=>`<span class="feature-pill">${f}</span>`).join('')}</div>
    <div class="kpi-row">
      ${d.kpis.map(k=>`<div class="kpi-mini"><div class="k-val">${k.val}</div><div class="k-label">${k.label}</div></div>`).join('')}
    </div>
  `;
}

function buildChat(key){
  const chat = document.getElementById('demo-chat');
  chat.innerHTML = '';
  scenarios[key].messages.forEach((m,i)=>{
    const id = `${key}_${i}`;
    if(m.type==='chip'){
      const el = document.createElement('span');
      el.className='wa-chip'; el.id=`chip_${id}`; el.textContent=m.text; el.style.display='none';
      chat.appendChild(el);
    } else if(m.type==='typing'){
      const el = document.createElement('div');
      el.className='wa-typing'; el.id=`ty_${id}`;
      el.innerHTML='<div class="wa-dot"></div><div class="wa-dot"></div><div class="wa-dot"></div>';
      chat.appendChild(el);
    } else if(m.type==='user'){
      const el = document.createElement('div');
      el.className='wa-msg wa-user first'; el.id=`msg_${id}`; el.style.display='none';
      if(m.triggerId) el.dataset.triggerId=m.triggerId;
      let inner = '';
      if(m.quoted) inner+=`<div class="msg-body"><div style="border-left:3px solid #075E54;background:rgba(0,0,0,0.06);border-radius:0 4px 4px 0;padding:4px 8px;margin:4px 0 2px;"><div style="font-size:10px;font-weight:600;color:#075E54;">Kaito</div><div style="font-size:10px;color:#667781;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${m.quoted}</div></div>${m.msg}</div>`;
      else inner+=`<div class="msg-body">${m.msg}</div>`;
      inner+=`<div class="msg-meta"><span class="msg-time">10:${String(i).padStart(2,'0')}</span><span class="msg-ticks grey">✓✓</span></div>`;
      el.innerHTML=inner; chat.appendChild(el);
    } else if(m.type==='bot'){
      const el = document.createElement('div');
      el.className='wa-msg wa-bot first'; el.id=`msg_${id}`; el.style.display='none';
      let inner=`<div class="msg-body">${m.msg}</div>`;
      if(m.buttons&&m.buttons.length){
        inner+='<div class="wa-msg-btns">';
        m.buttons.forEach(btn=>{
          const cls=btn.url?'type-url':'type-reply';
          const tid=btn.triggerId?` data-trigger="${btn.triggerId}"`:'';
          inner+=`<div class="wa-btn ${cls}"${tid}>${btn.text}</div>`;
        });
        inner+='</div>';
      }
      inner+=`<div class="msg-meta"><span class="msg-time">10:${String(i).padStart(2,'0')}</span><span class="msg-ticks">✓✓</span></div>`;
      el.innerHTML=inner; chat.appendChild(el);
    }
  });
}

function schedulePlay(key){
  currentTimers.forEach(t=>clearTimeout(t)); currentTimers=[];
  const chat=document.getElementById('demo-chat');
  const msgs=scenarios[key].messages;
  let cum=0;
  for(let i=0;i<msgs.length;i++){
    const m=msgs[i]; cum+=m.delay||0; const idx=i;
    const t=setTimeout(()=>{
      if(m.type==='chip'){
        const el=document.getElementById(`chip_${key}_${idx}`);
        if(el){el.style.display='block'; chat.scrollTop=chat.scrollHeight;}
      } else if(m.type==='typing'){
        const el=document.getElementById(`ty_${key}_${idx}`);
        if(el){el.classList.add('show'); chat.scrollTop=chat.scrollHeight;}
      } else {
        const prev=document.getElementById(`ty_${key}_${idx-1}`);
        if(prev) prev.classList.remove('show');
        const el=document.getElementById(`msg_${key}_${idx}`);
        if(el&&el.style.display==='none'){
          el.style.display='block';
          requestAnimationFrame(()=>{el.classList.add('show'); chat.scrollTop=chat.scrollHeight;});
        }
      }
    },cum);
    currentTimers.push(t);
  }
}

function renderScenario(key){
  currentTimers.forEach(t=>clearTimeout(t)); currentTimers=[];
  buildInfo(key); buildChat(key); schedulePlay(key);
}

function resetAndPlay(){ renderScenario(currentScenario); }

document.addEventListener('click',e=>{
  const btn=e.target.closest('.wa-btn');
  if(!btn) return;
  const wrap=btn.closest('.wa-msg-btns');
  if(!wrap) return;
  if(btn.classList.contains('chosen')) return;
  const triggerId=btn.dataset.trigger;
  wrap.querySelectorAll('.wa-btn').forEach(b=>b===btn?b.classList.add('chosen'):b.classList.add('unchosen'));
  if(triggerId){
    const chat=document.getElementById('demo-chat');
    const um=chat.querySelector(`.wa-msg[data-trigger-id="${triggerId}"]`);
    if(um&&um.style.display==='none'){
      um.style.display='block';
      requestAnimationFrame(()=>{um.classList.add('show'); chat.scrollTop=chat.scrollHeight;});
    }
  }
});

document.querySelectorAll('.s-tab').forEach(tab=>{
  tab.addEventListener('click',function(){
    const key=this.dataset.scenario;
    if(key===currentScenario) return;
    document.querySelectorAll('.s-tab').forEach(t=>t.classList.remove('active'));
    this.classList.add('active');
    currentScenario=key;
    renderScenario(key);
  });
});

/* ══════════════════════════════
   MODAL
══════════════════════════════ */
function openModal(src){
  document.getElementById('modal-img').src=src;
  document.getElementById('modal').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeModal(){
  document.getElementById('modal').classList.remove('open');
  document.body.style.overflow='';
}
document.addEventListener('keydown',e=>{ if(e.key==='Escape') closeModal(); });

/* ══════════════════════════════
   COUNTERS
══════════════════════════════ */
function animateCounter(el){
  const target=parseInt(el.dataset.target);
  if(isNaN(target)) return;
  const fmt=el.dataset.format;
  const dur=1800; const start=performance.now();
  (function tick(now){
    const p=Math.min((now-start)/dur,1);
    const ease=1-Math.pow(1-p,3);
    const val=Math.round(target*ease);
    if(fmt==='k') el.textContent=(val>=1000?(val/1000).toFixed(0)+'K':val);
    else el.textContent=val.toLocaleString();
    if(p<1) requestAnimationFrame(tick);
  })(start);
}

/* ══════════════════════════════
   INTERSECTION OBSERVER
══════════════════════════════ */
const io=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.classList.add('visible');
      // counter
      if(e.target.classList.contains('counter')) animateCounter(e.target);
      // bar fill
      const bar=e.target.querySelector('.kpi-bar-fill');
      if(bar) bar.style.width=(bar.dataset.width||0)+'%';
      io.unobserve(e.target);
    }
  });
},{threshold:.2});

/* Timeline items */
document.querySelectorAll('.tl-item').forEach(el=>io.observe(el));
/* Reveal */
document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
/* Counters */
document.querySelectorAll('.counter').forEach(el=>io.observe(el));
/* Bar fills */
document.querySelectorAll('.hero-kpi').forEach(el=>io.observe(el));

/* ══════════════════════════════
   INIT
══════════════════════════════ */
document.addEventListener('DOMContentLoaded',()=>{
  renderScenario('scenario-1');
});
</script>
</body>
</html>